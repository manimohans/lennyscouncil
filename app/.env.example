# Local Postgres (created by scripts/bootstrap-db.sh)
DATABASE_URL=postgresql://lr_app:roundtable_dev@localhost:5432/lennys_roundtable

# Ollama — single endpoint for both embeddings and chat
# WSL → Windows host: discover with `ip route show default | awk '{print $3}'`
# Linux/macOS native: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=kimi-k2.6:cloud

# Ollama Cloud REST API key — required for web_search / web_fetch enrichment.
# Get from https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=

# Path to the corpus on disk (for ingestion script)
CORPUS_PATH=../lennys-newsletterpodcastdata-all

# Session secret (used by auth — generate any 32+ char random string)
AUTH_SECRET=
